{
  "name": "complyze-desktop",
  "productName": "Complyze",
  "version": "1.0.0",
  "description": "Complyze Desktop Agent",
  "author": "Complyze",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "build": "echo 'Build step not required for pure Node.js daemon'",
    "diagnose": "node scripts/diagnose.js"
  },
  "build": {
    "appId": "com.complyze.desktop",
    "productName": "Complyze",
    "copyright": "Copyright © 2026 Complyze",
    "afterSign": "scripts/notarize.js",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "forceCodeSigning": false
    },
    "dmg": {
      "sign": false
    },
    "files": [
      "**/*",
      "!dist"
    ],
    "protocols": {
      "name": "complyze-agent",
      "schemes": [
        "complyze"
      ]
    },
    "electronVersion": "34.0.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.7"
  },
  "dependencies": {
    "csv-parse": "^6.1.0",
    "csv-parser": "^3.2.0",
    "firebase": "^12.9.0",
    "mammoth": "^1.11.0",
    "node-forge": "^1.3.3",
    "pdf-parse": "^2.4.5",
    "sudo-prompt": "^9.2.1",
    "uuid": "^11.1.0"
  }
}