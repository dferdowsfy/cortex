{
    "manifest_version": 3,
    "name": "Complyze Zero-Trust Shield",
    "version": "1.4.0",
    "description": "Enterprise AI governance and compliance monitor.",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        },
        "default_title": "Complyze Shield"
    },
    "permissions": [
        "storage",
        "identity",
        "alarms",
        "tabs",
        "sidePanel",
        "scripting"
    ],
    "host_permissions": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://openrouter.ai/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://huggingface.co/chat/*",
        "https://poe.com/*",
        "https://api.complyze.co/*",
        "https://complyze.co/*",
        "https://identitytoolkit.googleapis.com/*",
        "https://securetoken.googleapis.com/*",
        "https://myagent-846c3.firebaseio.com/*"
    ],
    "side_panel": {
        "default_path": "sidebar.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://chatgpt.com/*",
                "https://chat.openai.com/*",
                "https://claude.ai/*",
                "https://gemini.google.com/*",
                "https://aistudio.google.com/*",
                "https://openrouter.ai/*",
                "https://perplexity.ai/*",
                "https://www.perplexity.ai/*",
                "https://copilot.microsoft.com/*",
                "https://chat.deepseek.com/*",
                "https://chat.mistral.ai/*",
                "https://huggingface.co/chat/*",
                "https://poe.com/*"
            ],
            "js": [
                "promptScanner.js"
            ],
            "run_at": "document_idle",
            "all_frames": true
        },
        {
            "matches": [
                "https://chatgpt.com/*",
                "https://chat.openai.com/*",
                "https://claude.ai/*",
                "https://gemini.google.com/*",
                "https://aistudio.google.com/*",
                "https://openrouter.ai/*",
                "https://perplexity.ai/*",
                "https://www.perplexity.ai/*",
                "https://copilot.microsoft.com/*",
                "https://chat.deepseek.com/*",
                "https://chat.mistral.ai/*",
                "https://huggingface.co/chat/*",
                "https://poe.com/*"
            ],
            "js": [
                "fetchShim.js"
            ],
            "run_at": "document_start",
            "all_frames": true,
            "world": "MAIN"
        }
    ]
}