# Complyze uses a locally-hosted Ollama instance for ALL LLM inference.
# All prompt analysis and risk scoring MUST occur locally — never via external APIs.
# Install Ollama: https://ollama.com/  then run: ollama pull complyze-qwen
# The service will be available at http://localhost:11434 by default.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=complyze-qwen
OLLAMA_TIMEOUT_MS=30000

# -----------------------------------------------------------------------
# Proxy Validation Test Harness configuration
# -----------------------------------------------------------------------

# Complyze local proxy host and port
PROXY_HOST=127.0.0.1
PROXY_PORT=8080

# Proxy log API endpoint (exposes intercepted request logs)
PROXY_LOG_URL=http://localhost:3737/logs

# Optional bearer token for proxy log API authentication
PROXY_LOG_API_KEY=

# API keys used to generate real traffic for interception testing
# Tests use dummy values if not set, but real keys give better coverage
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=

# Set to 1 to abort test run if preflight connectivity checks fail
STRICT_PREFLIGHT=0

# Set to 1 for verbose Playwright and Tesseract output
VERBOSE=0
